# ============================================================
# Scano Growth Agent – Environment Variables
# Copy to .env.local for development
# Add all to Vercel project settings for production
# ============================================================

# ── Supabase (already have these) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NEVER expose to browser

# ── OpenRouter (already have this) ──────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Google PageSpeed (free, optional but recommended) ────────
GOOGLE_PAGESPEED_API_KEY=AIza...
# Get at: https://console.cloud.google.com → PageSpeed Insights API

# ── GitHub App ───────────────────────────────────────────────
# Create at: https://github.com/settings/apps/new
# Permissions needed: Contents (R/W), Pull requests (R/W), Metadata (R)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_BASE64=LS0t...   # base64 of the .pem file
# openssl base64 -in private-key.pem | tr -d '\n'
GITHUB_CLIENT_ID=Iv1.abc...
GITHUB_CLIENT_SECRET=abc...

# ── Telegram Bot ─────────────────────────────────────────────
# Create bot: message @BotFather → /newbot
# Set webhook after deploy:
# curl -X POST https://api.telegram.org/bot{TOKEN}/setWebhook \
#   -H "Content-Type: application/json" \
#   -d '{"url":"https://your-domain.com/api/webhooks/telegram","secret_token":"your-secret"}'
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_WEBHOOK_SECRET=generate-random-32-char-string

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Price IDs from Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# ── Security ─────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_TOKEN_ENCRYPTION_KEY=64-hex-chars-for-aes-256
AGENT_APPROVAL_TOKEN_SECRET=32-hex-chars-for-hmac
AGENT_CRON_SECRET=32-hex-chars-for-cron-auth

# ── Optional: Plausible (if self-hosting) ───────────────────
PLAUSIBLE_HOST=https://plausible.io   # or your self-hosted URL

# ── Optional: Trigger.dev (for reliable cron) ───────────────
TRIGGER_API_KEY=tr_dev_...
TRIGGER_API_URL=https://api.trigger.dev
